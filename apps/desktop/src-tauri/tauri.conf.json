{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vessel",
  "version": "0.1.0",
  "identifier": "com.vessel.desktop",
  "build": {
    "beforeDevCommand": "cd ../.. && npm run build --workspace=client && cargo build --release -p server && HOST=$(rustc -vV | sed -n 's/^host: //p') && BIN=target/release/server && cp \"$BIN\" \"${BIN}-${HOST}\" && npm run dev:vite --workspace=client",
    "beforeBuildCommand": "cd ../.. && npm run build --workspace=client && cargo build --release -p server && bash scripts/bundle-macos-deps.sh && HOST=$(rustc -vV | sed -n 's/^host: //p') && BIN=target/release/server && cp \"$BIN\" \"${BIN}-${HOST}\"",
    "devUrl": "http://localhost:5175",
    "frontendDist": "../../client/dist"
  },
  "app": {
    "security": {
      "capabilities": ["main"]
    },
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Vessel",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "externalBin": ["../../../target/release/server"],
    "resources": {
      "../../../target/bundle-staging/libs": "libs",
      "../../../target/bundle-staging/gstreamer-1.0": "gstreamer-1.0",
      "../../../target/bundle-staging/python3.12": "python3.12"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["vessel"]
      }
    },
    "prevent-default": {
      "back": true,
      "backspace": true,
      "alt-left": true,
      "alt-right": true
    }
  }
}
